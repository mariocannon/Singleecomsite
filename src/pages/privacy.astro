---
import BaseLayout from '../layouts/BaseLayout.astro';
import DevBanner from '../components/DevBanner.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="Privacy policy — ZENZKO">
  <DevBanner message="MOCKUP" />
  <Header />

  <div class="container-narrow form-page legal-page">
    <p class="eyebrow">Legal</p>
    <h1 style="font-size:28px; margin-bottom:20px;">Privacy Policy</h1>

    <div class="legal-page-note">
      This is placeholder text for a working mockup, not a real privacy policy. It needs to be reviewed.
    </div>

    <h2>What we collect</h2>
    <p>When you create a store, we store what you type into the form: product name, description, price, photos, and any optional details like delivery info or social links. If you choose to enter an email to have your links sent to you, we store that too.</p>
    <p>When someone buys from a store, payment details are handled entirely by Stripe — we never see or store card numbers.</p>

    <h2>Stripe's role</h2>
    <p>Payments run through Stripe Connect. Sellers have their own direct relationship with Stripe, separate from us. Stripe's own privacy policy governs the payment information they collect during onboarding and checkout.</p>

    <h2>What we don't do</h2>
    <p>We don't sell data to third parties, and we don't run ad tracking on store pages.</p>

    <h2>Contact</h2>
    <p>Questions about this policy can go to <a href="mailto:privacy@zenzko.com">privacy@peg.store</a> (placeholder address).</p>
  </div>

  <Footer />
</BaseLayout>
