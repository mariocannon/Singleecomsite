---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const featuredStores = [
  {
    slug: 'kowhai-candles',
    shopName: 'Kōwhai Candle Co.',
    productName: 'Soy Candle — Kōwhai & Bergamot',
    price: '$24.00',
    photo: 'https://images.unsplash.com/photo-1602874801007-bd458bb1b8b6?w=600&q=80',
    stat: '22 of 30 sold in the first week — no ads, just an Instagram story.'
  },
  {
    slug: 'marsh-prints',
    shopName: 'Marsh & Co',
    productName: 'Limited Print — "Low Tide"',
    price: '$65.00',
    photo: 'https://images.unsplash.com/photo-1515405295579-ba7b45403062?w=600&q=80',
    stat: 'Sold out in 6 days. Buyers found it through a single Instagram post.'
  },
  {
    slug: 'baileys-bakes',
    shopName: "Bailey's Bakes",
    productName: 'Banana Bread Loaf',
    price: '$8.00',
    photo: 'https://images.unsplash.com/photo-1605286978633-2dec93ff88a2?w=600&q=80',
    stat: 'Sells out most Fridays before the school run even starts.'
  }
];
---
<BaseLayout title="ZENZKO — sell one thing, no account needed">
  <Header />

  <section class="hero">
    <div class="container hero">
      <div>
        <p class="eyebrow">For people selling one thing</p>
        <h1>One product. One page. No account.</h1>
        <p class="sub">Add your product, connect Stripe, and get a link you can share today. No dashboard to learn, no store to manage, just a page that takes payment.</p>
        <div class="hero-ctas">
          <a class="btn-primary" href="/create">Create your store for free</a>
          <span class="hero-note">Takes about 3 minutes</span>
        </div>
      </div>
      <div class="hero-visual">
        <a href="/create" style="text-decoration:none; color:inherit;">
          <div class="tag-hole"></div>
          <div class="tag-string"></div>
          <div class="mock-wrap">
            <div class="mock-card">
              <img class="mock-photo" src="https://images.unsplash.com/photo-1610701596007-11502861dcfa?w=400&q=80" alt="" />
              <p class="mock-shop">Fen & Clay</p>
              <p class="mock-name">Speckled Stoneware Mug</p>
              <div class="mock-price-row">
                <span class="mock-price">$38.00</span>
                <span class="mock-stock">4 left</span>
              </div>
              <div class="mock-btn">Buy now</div>
            </div>
          </div>
        </a>
      </div>
    </div>
  </section>

  <section class="steps">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">How it works</p>
        <h2>Three steps, then you're live</h2>
      </div>
      <div class="steps-grid">
        <div class="step">
          <p class="step-num">01</p>
          <h3>Add your product</h3>
          <p>Name, photo, price, and whatever else people need to know — pickup info, a note about you, your socials. Only a name, photo, and price are required.</p>
        </div>
        <div class="step">
          <p class="step-num">02</p>
          <h3>Connect Stripe</h3>
          <p>Payments go straight to your own Stripe account. We never hold your money — it lands with you the same way it would with any Stripe payment.</p>
        </div>
        <div class="step">
          <p class="step-num">03</p>
          <h3>Publish your link</h3>
          <p>You get a page at yourshop.peg.store. Share it anywhere. Publishing is final on the free plan, so give it a last look first.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="pricing">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Pricing</p>
        <h2>No monthly fee. We only make money when you do.</h2>
      </div>
      <div class="pricing-grid">
        <div class="price-card">
          <h3>Free</h3>
          <p class="tag">Default</p>
          <ul>
            <li>One product page</li>
            <li>Your own Stripe account</li>
            <li>Locked once published</li>
          </ul>
          <p class="fee-line">Stripe fee (2.65% + NZ$0.30) + ZENZKO 6%</p>
        </div>
        <div class="price-card featured">
          <h3>Unlocked</h3>
          <p class="tag">One-time upgrade</p>
          <ul>
            <li>Everything in Free</li>
            <li>Edit price, photos, and text anytime</li>
            <li>Re-publish as often as you like</li>
          </ul>
          <p class="fee-line">Coming soon</p>
        </div>
      </div>
    </div>
  </section>

  <section class="uses">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Made for</p>
        <h2>If it's one thing, it belongs here</h2>
      </div>
      <div class="chips">
        <a class="chip" href="/use-cases/honesty-box-stands">Honesty box stands</a>
        <a class="chip" href="/use-cases/one-off-makers">One-off makers</a>
        <a class="chip" href="/use-cases/small-batch-drops">Small-batch drops</a>
        <a class="chip" href="/use-cases/market-stall-sellers">Market stall sellers</a>
        <a class="chip" href="/use-cases/limited-prints">Limited prints</a>
        <a class="chip" href="/use-cases/single-item-fundraisers">Single-item fundraisers</a>
      </div>
    </div>
  </section>

  <section class="featured">
    <div class="container">
      <div class="section-head">
        <p class="eyebrow">Example stores</p>
        <h2>Three ways people are using ZENZKO</h2>
      </div>
      <div class="featured-grid">
        {featuredStores.map(store => (
          <div class="featured-card">
            <img src={store.photo} alt={store.productName} />
            <div class="featured-card-body">
              <p class="featured-shop">{store.shopName}</p>
              <p class="featured-name">{store.productName}</p>
              <div class="featured-price-row">
                <span class="featured-price">{store.price}</span>
              </div>
              <p class="featured-stat">{store.stat}</p>
              <div class="featured-actions">
                <button type="button" class="case-study-btn" data-slug={store.slug}>Read case study</button>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div id="case-modal-overlay" class="modal-overlay hidden">
    <div class="modal" id="case-modal-body"></div>
  </div>

  <Footer />

  <script is:inline>
    const caseStudies = {
      'kowhai-candles': {
        title: 'Kōwhai Candle Co.',
        body: [
          'Before ZENZKO, candles moved through word of mouth and a cash tin at the school gate — no way to take an order unless she was standing right there.',
          'She listed one candle, connected Stripe in about five minutes, and swapped her usual "DM me to order" Instagram caption for a direct link to the page.',
          '22 of the first batch of 30 sold within a week, almost all to people she\'d never spoken to before. She\'s restocked wax twice since.'
        ]
      },
      'marsh-prints': {
        title: 'Marsh & Co',
        body: [
          'Print drops used to run through Instagram DMs, with orders and bank transfers tracked by hand in a notebook — easy to lose track of who\'d actually paid.',
          'The numbered edition of 20 went up on the Unlocked plan, which mattered on day two when a typo in the print description needed fixing without pulling the whole page down.',
          'All 20 prints sold within 6 days, entirely off the back of a single Instagram post linking straight to checkout.'
        ]
      },
      'baileys-bakes': {
        title: "Bailey's Bakes",
        body: [
          'The honesty-box stand ran on a cash tin for years — mostly reliable, but some weeks it came up short and there was no way to know why.',
          'A ZENZKO link went up on the stand sign so people could pay by card before picking up their loaf. The cash tin stayed as a backup for anyone without a phone on them.',
          'The loaf now sells out most Fridays before the school run even starts, and coming up short has stopped being something to plan around.'
        ]
      }
    };

    document.querySelectorAll('.case-study-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const cs = caseStudies[btn.getAttribute('data-slug')];
        if (!cs) return;
        const overlay = document.getElementById('case-modal-overlay');
        const body = document.getElementById('case-modal-body');
        body.innerHTML = `
          <h3>${cs.title}</h3>
          <div class="case-modal-body">${cs.body.map(p => `<p>${p}</p>`).join('')}</div>
          <button class="btn-primary" id="close-case" style="width:100%;">Close</button>
        `;
        overlay.classList.remove('hidden');
        document.getElementById('close-case').addEventListener('click', () => {
          overlay.classList.add('hidden');
        });
      });
    });
  </script>
</BaseLayout>

<style>
  .hero{ padding-top: 72px; padding-bottom: 88px; display:grid; grid-template-columns: 1.1fr 0.9fr; gap: 48px; align-items:center; }
  .hero h1{ font-size: 48px; line-height: 1.06; margin: 0 0 20px; }
  .hero p.sub{ font-size: 17px; line-height: 1.6; color: var(--muted); max-width: 440px; margin: 0 0 30px; }
  .hero-ctas{ display:flex; align-items:center; gap: 18px; flex-wrap:wrap; }
  .hero-note{ font-family:'IBM Plex Mono', monospace; font-size: 12px; color: var(--muted); }
  .hero-visual{ display:flex; justify-content:center; }
  .mock-wrap{ transform: rotate(-3deg); }
  .mock-card{ width: 230px; background:#fff; border: 1px solid var(--line); border-radius: 10px; padding: 16px 16px 18px; box-shadow: 0 20px 40px -18px rgba(0,0,0,0.25); }
  .mock-photo{ width:100%; aspect-ratio: 1/1; border-radius:6px; object-fit:cover; margin-bottom: 12px; background:#eee; }
  .mock-shop{ font-family:'IBM Plex Mono', monospace; font-size: 9.5px; letter-spacing: 0.8px; text-transform: uppercase; color: var(--muted); margin: 0 0 4px; }
  .mock-name{ font-family:'Space Grotesk', sans-serif; font-weight:700; font-size: 15px; margin: 0 0 10px; }
  .mock-price-row{ display:flex; justify-content:space-between; align-items:center; margin-bottom: 10px; }
  .mock-price{ font-family:'Space Grotesk', sans-serif; font-weight:700; font-size:14px; }
  .mock-stock{ font-family:'IBM Plex Mono', monospace; font-size:10px; color: var(--accent); }
  .mock-btn{ background: var(--accent); color:#fff; text-align:center; border-radius:5px; padding: 8px; font-size: 12px; font-weight:600; }

  section.steps{ padding: 70px 0; border-top: 1px solid var(--line); }
  .section-head{ max-width: 480px; margin-bottom: 40px; }
  .section-head h2{ font-size: 30px; }
  .steps-grid{ display:grid; grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .step-num{ font-family:'IBM Plex Mono', monospace; font-size: 13px; color: var(--accent); margin-bottom: 10px; }
  .step h3{ font-size: 18px; margin: 0 0 8px; }
  .step p{ font-size: 14.5px; line-height:1.6; color: var(--muted); margin:0; }

  section.pricing{ padding: 70px 0; border-top: 1px solid var(--line); }
  .pricing-grid{ display:grid; grid-template-columns: 1fr 1fr; gap: 24px; }
  .price-card{ border: 1px solid var(--line); border-radius: 10px; padding: 28px; background: #fff; }
  .price-card.featured{ border-color: var(--ink); }
  .price-card h3{ font-size: 20px; margin: 0 0 6px; }
  .price-card .tag{ font-family:'IBM Plex Mono', monospace; font-size: 11px; letter-spacing: 0.8px; text-transform: uppercase; color: var(--muted); margin: 0 0 18px; }
  .price-card ul{ margin: 0; padding: 0 0 0 18px; font-size: 14.5px; line-height: 1.9; }
  .fee-line{ font-family:'IBM Plex Mono', monospace; font-size: 13px; color: var(--muted); margin-top: 20px; padding-top: 16px; border-top: 1px dashed var(--line); }

  section.uses{ padding: 60px 0 90px; border-top: 1px solid var(--line); }
  .chips{ display:flex; flex-wrap:wrap; gap: 10px; }
  .chip{ border: 1px solid var(--line); background:#fff; border-radius: 100px; padding: 9px 16px; font-size: 13.5px; text-decoration:none; transition: border-color 0.15s ease, color 0.15s ease; }
  .chip:hover{ border-color: var(--accent); color: var(--accent); }

  section.featured{ padding: 70px 0 90px; border-top: 1px solid var(--line); }
  .featured-grid{ display:grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .featured-card{
    display:block; text-decoration:none; color:inherit;
    background:#fff; border: 1px solid var(--line); border-radius: 10px;
    overflow:hidden; transition: box-shadow 0.15s ease, transform 0.15s ease;
  }
  .featured-card:hover{ box-shadow: 0 16px 32px -18px rgba(0,0,0,0.25); transform: translateY(-2px); }
  .featured-card img{ width:100%; aspect-ratio: 4/3; object-fit:cover; display:block; }
  .featured-card-body{ padding: 16px 18px 18px; }
  .featured-shop{
    font-family:'IBM Plex Mono', monospace; font-size: 10.5px; letter-spacing: 0.8px;
    text-transform: uppercase; color: var(--muted); margin: 0 0 4px;
  }
  .featured-name{ font-family:'Space Grotesk', sans-serif; font-weight:700; font-size: 16px; margin: 0 0 12px; }
  .featured-price-row{ display:flex; justify-content:space-between; align-items:center; margin-bottom: 12px; }
  .featured-price{ font-family:'Space Grotesk', sans-serif; font-weight:700; font-size: 15px; }
  .featured-link{ font-family:'IBM Plex Mono', monospace; font-size: 11px; color: var(--accent); }
  .featured-stat{
    font-size: 13px; line-height: 1.5; color: var(--muted);
    margin: 0 0 14px; padding-top: 12px; border-top: 1px dashed var(--line);
  }
  .featured-actions{ display:flex; align-items:center; justify-content:space-between; gap: 12px; }
  .featured-actions a{
    font-family:'IBM Plex Mono', monospace; font-size: 11px; color: var(--accent);
    text-decoration:none;
  }
  .featured-actions a:hover{ text-decoration:underline; }
  .case-study-btn{
    background:none; border:none; padding:0; cursor:pointer;
    font-size: 12.5px; color: var(--muted); text-decoration:underline;
  }
  .case-study-btn:hover{ color: var(--ink); }
  .case-modal-body p{ font-size: 14px; line-height: 1.6; margin: 0 0 14px; text-align:left; color: var(--ink); }
  .case-modal-body p:last-of-type{ margin-bottom: 20px; }

  @media (max-width: 820px){
    .hero{ grid-template-columns: 1fr; padding-top: 48px; padding-bottom: 60px; }
    .hero-visual{ order: -1; }
    .hero h1{ font-size: 36px; }
    .steps-grid{ grid-template-columns: 1fr; }
    .pricing-grid{ grid-template-columns: 1fr; }
    .featured-grid{ grid-template-columns: 1fr; }
  }
</style>
